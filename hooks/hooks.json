{
  "description": "claudex-power-commands: SessionStart dependency check + Stop early-stop guard (the runtime entrance the self-enforced Meta-Loop lacks)",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-deps.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/finish-the-work.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
